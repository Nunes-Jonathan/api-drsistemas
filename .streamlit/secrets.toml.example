[wsretaguarda]
dominio  = "your-dominio"
endpoint = "https://wsretaguarda.saurus.net.br/v001/serviceRetaguarda.asmx"
# xsenha is computed daily from the date — formula:
#   base64("ophd02ophd02|@{day + month + (year - 2000)}|misam")
# Leave it empty to use the live computation. Only set this if Saurus gives
# you a non-standard override password for testing.
# xsenha = ""

[postgres]
host        = "database-1.cluster-cx8gk8sogfmb.us-east-2.rds.amazonaws.com"
port        = 5432
database    = "postgres"
schema      = "drsistemas"
user        = "postgres"
sslmode     = "verify-full"
# System CA bundle on Debian/Ubuntu/WSL — works with RDS because Amazon's
# root CAs are in ca-certificates. On other distros adjust the path
# (e.g. /etc/pki/tls/certs/ca-bundle.crt on RHEL/Fedora).
sslrootcert = "/etc/ssl/certs/ca-certificates.crt"

[aws]
region = "us-east-2"
# profile = "default"   # optional; otherwise uses env vars / instance role

[sync]
max_id_produto              = 10000
default_sales_lookback_days = 90
soap_max_workers            = 4
soap_timeout_seconds        = 60
